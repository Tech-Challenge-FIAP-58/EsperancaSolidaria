# Variaveis de ambiente para o container do UserService.
# Copie para .env e preencha com valores reais. O .env real NAO vai para o git.
# ASP.NET mapeia "__" para ":"  ->  Jwt__Key vira a config Jwt:Key.
#
# Uso:
#   docker run --env-file .env -p 8080:8080 user-service:latest
#   (ou referencie via `env_file: .env` num servico do docker-compose)

Jwt__Key=<gerar 32+ bytes aleatorios>
Mongo__ConnectionString=<mongodb+srv://usuario:senha@host/db>
BootstrapGestor__Email=<email do gestor>
BootstrapGestor__Cpf=<cpf do gestor>
BootstrapGestor__Password=<senha do gestor>

# Quando a API roda em container junto do RabbitMQ (mesma rede do compose),
# o host do broker passa a ser o nome do servico, nao "localhost":
# RabbitMQ__Host=rabbitmq
